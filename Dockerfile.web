FROM node:22-alpine

WORKDIR /app

COPY package.json tsconfig.base.json .env.example ./
COPY apps ./apps
COPY packages ./packages

RUN npm install --workspace apps/web --include-workspace-root

EXPOSE 5173
CMD ["npm", "run", "dev", "--workspace", "apps/web", "--", "--host", "0.0.0.0", "--port", "5173"]
