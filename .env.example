NODE_ENV=development
APP_PORT=3000
# Set to true only if you explicitly want demo data loaded on container startup.
SEED_DEMO_DATA=false
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
AUTH_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
PATIENT_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
DOCTOR_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
AVAILABILITY_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
APPOINTMENT_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
MEDICAL_RECORDS_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
NOTIFICATION_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
AUDIT_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
REALTIME_SERVICE_DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
JWT_ACCESS_SECRET=super-secret-access-token-value
JWT_REFRESH_SECRET=super-secret-refresh-token-value
JWT_ISSUER=patient-auth
OTP_TTL_SECONDS=300
FRONTEND_ORIGIN=http://localhost:5173
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/login
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
STAFF_INVITE_TTL_SECONDS=172800
ADMIN_BOOTSTRAP_EMAIL=admin@hospital.local
ADMIN_BOOTSTRAP_PASSWORD=change-this-bootstrap-password
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
# For Gmail use:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_FROM should usually match SMTP_USER
SMTP_FROM=no-reply@hospital.local
SMTP_SECURE=false
